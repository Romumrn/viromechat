.DS_Store
logs/*
data*
**/__pycache__/
.pytest_cache/
.claude/
# Secrets — see .env.app.example / .env.mcp.example for the expected keys
.env
.env.app
.env.mcp
.streamlit/secrets.toml

# Local user accounts (usernames, bcrypt-hashed passwords, cookie key):
# keep the directory tracked (so the Docker bind-mount has a host dir owned
# by the host user before first run) but never commit the credentials file.
auth_data/*
!auth_data/.gitkeep
test_neo4j.ipynb
test_S3MCP.ipynb
.gitignore
