# Copy to .env.app and fill in — loaded by app.py (Streamlit client).
# On Streamlit Community Cloud, use .streamlit/secrets.toml instead; it
# takes priority over these values when both are present.

ALBERT_API_KEY=

# User accounts are always required to use the app — login + self-service
# registration, backed by a local YAML file (.streamlit_auth.yaml, created
# automatically, gitignored). No external identity provider. Nothing to
# configure here.
