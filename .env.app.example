# Copy to .env.app and fill in — loaded by app.py (Streamlit client).
# On Streamlit Community Cloud, use .streamlit/secrets.toml instead; it
# takes priority over these values when both are present.

ALBERT_API_KEY=

# User accounts are always required to use the app — login + self-service
# registration, backed by a local SQLite database (auth_data/viromechat.db,
# created automatically, gitignored). No external identity provider. On first
# run, any pre-existing auth_data/.streamlit_auth.yaml accounts and
# logs/user_histories/*.json chat history are imported into the database.

# Optional shared invite code gating account creation: if set, a new user
# must enter this exact code (in addition to email/password/captcha) to
# register. Leave empty/omit to keep registration open to anyone.
# REGISTRATION_CODE=

# Comma-separated list of emails granted the 'admin' role (access to the Admin
# page: read-only view of all users and their conversations). Applied both to
# new registrations and to accounts imported on first run. Leave empty for no
# admins. Example: ADMIN_EMAILS=alice@lab.fr,bob@univ.fr
# ADMIN_EMAILS=
