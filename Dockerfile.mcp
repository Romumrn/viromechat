# MCP data server (server_mcp.py) — owns the taxonomy CSV and the S3 host
# Parquet dataset (via DuckDB), exposes them as MCP tools/resources over
# HTTP. See Dockerfile.app for the Streamlit client that talks to it.

FROM python:3.11-slim

WORKDIR /app

# Installe les dépendances Python (server_mcp.py uniquement — voir requirements-mcp.txt)
COPY requirements-mcp.txt .
RUN pip install --no-cache-dir -r requirements-mcp.txt

# Crée un utilisateur non-root pour des raisons de sécurité, avec un vrai
# HOME (writable) : "adduser --system" seul donne HOME=/nonexistent, et
# DuckDB a besoin d'un HOME accessible en écriture pour installer/charger
# l'extension httpfs (sinon : "IO Error: Can't find the home directory").
RUN addgroup --gid 1000 app \
    && adduser --uid 1000 --gid 1000 --system --home /home/app --shell /usr/sbin/nologin app \
    && mkdir -p /home/app && chown app:app /home/app
ENV HOME=/home/app

COPY --chown=app:app config.py server_mcp.py ./
# ./data est monté en lecture seule au runtime (voir docker-compose.yml) —
# pas besoin d'écrire sous /app, donc pas de chown supplémentaire ici.

EXPOSE 8000

USER app

CMD ["python", "server_mcp.py"]
